#!/usr/bin/env python3
"""
toggle_monitor_mode - Configures Hyprland monitor layouts based on connected displays.

By default, detects connected monitors and applies the best matching workspace.
Use --toggle to cycle through all compatible workspaces for the connected monitors.
Use --mode to explicitly select a workspace by name.
"""

import argparse
import json
import os
import re
import sys
import subprocess
from pathlib import Path
from typing import Dict, List, Optional, Any, Tuple

import yaml
from hyprpy import Hyprland
from hyprpy.components.monitors import Monitor


# Configuration paths
SCRIPT_DIR = Path(__file__).parent.resolve()
REPO_ROOT = SCRIPT_DIR.parent
CONFIG_DIR = Path.home() / ".config" / "hypr" / "config.d"
MONITORS_YAML = REPO_ROOT / "configs" / "displays" / "monitors.yaml"
WORKSPACES_YAML = REPO_ROOT / "configs" / "displays" / "workspaces.yaml"
STATE_FILE = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "monitor_mode_state"

# Valid position relationship keywords in workspace layout entries
POSITION_KEYWORDS = frozenset(["right_of", "left_of", "above", "below"])


def load_yaml(path: Path) -> Dict[str, Any]:
    """Load a YAML file and return its contents."""
    with open(path, 'r') as f:
        return yaml.safe_load(f)


def get_connected_monitors() -> List[Monitor]:
    """Get all currently connected monitors via hyprpy IPC.

    Uses the 'monitors all' command to include disabled monitors that are
    physically connected but not yet enabled. The default hyprpy get_monitors()
    only returns enabled monitors, missing displays that are connected but
    disabled by the current config.

    Forces a Hyprland reload first so that the monitor list reflects
    the actual physical connections (Hyprland can have a stale view).
    """
    instance = Hyprland()
    monitors_json = instance.command_socket.send_command('monitors', flags=['-j'], args=['all'])
    monitors = []
    for m in json.loads(monitors_json):
        try:
            monitors.append(Monitor(m, instance))
        except AttributeError:
            # Workaround for hyprpy bug: Monitor.__init__ references
            # data.mirror instead of data.mirror_of, causing an
            # AttributeError.  Build a minimal stand-in from the raw
            # JSON so the rest of the script still works.
            from types import SimpleNamespace
            mon = SimpleNamespace(
                id=m.get('id', -1),
                name=m.get('name', ''),
                model=m.get('model', ''),
                serial=m.get('serial', ''),
                width=m.get('width', 0),
                height=m.get('height', 0),
                is_disabled=m.get('disabled', False),
                mirror_of=None if m.get('mirrorOf', '') == '' else m.get('mirrorOf'),
            )
            monitors.append(mon)
    return monitors


def deduplicate_monitors(
    monitors: List[Monitor],
) -> Tuple[List[Monitor], Dict[str, List[Monitor]]]:
    """Deduplicate monitors that represent the same physical display.

    When the same monitor appears on multiple ports (e.g. DP-1 and DP-3),
    Hyprland reports it multiple times. We keep only one instance per
    physical monitor, preferring enabled over disabled instances.
    Duplicate entries are tracked so they can be configured as mirrors.

    Deduplication uses the (model, serial) pair from the actual monitor.
    Monitors with empty or missing serials are never deduplicated since we
    cannot reliably distinguish them from other monitors of the same model.

    Returns:
        A tuple of (deduplicated_monitors, mirrors) where mirrors maps
        each primary monitor's output name to the list of duplicate
        Monitor objects that should mirror it.
    """
    seen: Dict[tuple, int] = {}  # (model, serial) -> index in result
    result: List[Monitor] = []
    mirrors: Dict[str, List[Monitor]] = {}

    for monitor in monitors:
        serial = monitor.serial
        if not serial:
            # Can't reliably deduplicate without a serial number
            result.append(monitor)
            continue

        key = (monitor.model, serial)
        if key in seen:
            idx = seen[key]
            existing = result[idx]
            if not monitor.is_disabled and existing.is_disabled:
                # Current is enabled, existing is disabled -- swap primary
                result[idx] = monitor
                old_mirrors = mirrors.pop(existing.name, [])
                old_mirrors.append(existing)
                mirrors[monitor.name] = old_mirrors
            else:
                # Keep existing as primary, current becomes a mirror
                mirrors.setdefault(existing.name, []).append(monitor)
        else:
            seen[key] = len(result)
            result.append(monitor)

    return result, mirrors


def match_monitor(monitor: Monitor, configured_monitors: Dict[str, Dict]) -> List[str]:
    """
    Match a connected monitor to all configured monitors by model and serial.
    A single physical display can match multiple configured monitor IDs (e.g. different
    mode profiles for the same display). Returns a list of all matching config IDs.
    """
    matches = []
    for monitor_id, config in configured_monitors.items():
        model_match = config.get('model') == monitor.model
        serial = config.get('serial')

        # If serial is null/None in config, match only by model
        # Otherwise match both model and serial
        if serial is None or serial == "":
            if model_match:
                matches.append(monitor_id)
        else:
            if model_match and str(serial) == str(monitor.serial):
                matches.append(monitor_id)

    return matches


def get_workspace_monitors(workspace_config: Dict) -> List[str]:
    """Extract the list of monitor config IDs from a workspace's layout."""
    return [entry['monitor'] for entry in workspace_config.get('layout', [])]


def is_workspace_enabled(workspace_config: Dict) -> bool:
    """Check if a workspace is enabled for toggle cycling and auto-detection.

    Workspaces are enabled by default. Set ``enabled: false`` in the YAML
    to exclude a workspace from the toggle cycle and auto-detection.
    Disabled workspaces can still be selected explicitly via ``--mode``.
    """
    return workspace_config.get('enabled', True) is not False


def find_matching_workspace(
    monitor_match_map: Dict[str, List[str]],
    workspaces: Dict[str, Dict]
) -> Optional[Tuple[str, Dict]]:
    """
    Find the best matching workspace configuration for the connected monitors.

    monitor_match_map: Maps each physical monitor name to a list of all config IDs
                       it matched against. A single display can match multiple config
                       IDs (e.g. different mode profiles for the same hardware).

    Only considers enabled workspaces. Disabled workspaces are skipped.

    Returns tuple of (workspace_name, workspace_config) or None if no match.
    """
    # Build the set of all possible config IDs across all connected monitors
    all_possible_ids = set()
    for ids in monitor_match_map.values():
        all_possible_ids.update(ids)

    # Sort workspaces by number of monitors (descending) to prefer multi-monitor setups
    sorted_workspaces = sorted(
        workspaces.items(),
        key=lambda x: len(get_workspace_monitors(x[1])),
        reverse=True
    )

    for workspace_name, workspace_config in sorted_workspaces:
        if not is_workspace_enabled(workspace_config):
            continue

        required_monitors = set(get_workspace_monitors(workspace_config))

        # Check if all required monitors for this workspace are satisfiable
        # by the connected displays. Each required config ID must be present
        # in at least one connected display's match list.
        if required_monitors.issubset(all_possible_ids):
            return (workspace_name, workspace_config)

    return None


def parse_mode_resolution(mode: str) -> Optional[Tuple[int, int]]:
    """Parse width and height from a mode string like '3840x2160@60' or '1600x900'.

    Returns (width, height) if the mode contains a resolution, None otherwise
    (e.g. for 'preferred').
    """
    match = re.match(r'^(\d+)x(\d+)(?:@[\d.]+)?$', mode)
    if match:
        return int(match.group(1)), int(match.group(2))
    return None


def get_monitor_settings(configured_monitors: Dict[str, Dict], monitor_id: str) -> Dict[str, Any]:
    """Get settings for a monitor from configuration.

    Settings are optional - only specified settings override defaults.
    mode: "preferred" or "WIDTHxHEIGHT[@REFRESH_RATE]" (e.g., "3840x2160@144")
    vrr: true/false (default: false)
    scale: float (default: 1.0)
    """
    config = configured_monitors.get(monitor_id, {})
    settings = config.get('settings', {})

    # Start with defaults
    result = {
        'mode': 'preferred',
        'vrr': False,
        'scale': 1.0,
    }

    # Override with any specified settings
    if 'mode' in settings:
        result['mode'] = settings['mode']
    if 'vrr' in settings:
        result['vrr'] = settings['vrr']
    if 'scale' in settings:
        result['scale'] = settings['scale']

    return result


def get_monitor_dimensions(
    monitor_id: str,
    configured_monitors: Dict[str, Dict],
    monitor_objects: Dict[str, Monitor],
) -> Tuple[int, int]:
    """Get the pixel dimensions for a monitor.

    Uses the explicit mode resolution from config if available,
    otherwise falls back to the live monitor dimensions.
    """
    settings = get_monitor_settings(configured_monitors, monitor_id)
    mode_res = parse_mode_resolution(settings['mode'])
    if mode_res:
        return mode_res
    if monitor_id in monitor_objects:
        return monitor_objects[monitor_id].width, monitor_objects[monitor_id].height
    return 0, 0


def resolve_positions(
    layout: List[Dict],
    configured_monitors: Dict[str, Dict],
    monitor_objects: Dict[str, Monitor],
) -> Dict[str, Tuple[int, int]]:
    """Compute absolute (x, y) pixel positions from relational layout constraints.

    Each layout entry must specify either ``position: origin`` or exactly one
    relational keyword (right_of, left_of, above, below) referencing a monitor
    that has already been positioned earlier in the list.
    """
    positions: Dict[str, Tuple[int, int]] = {}

    for entry in layout:
        mid = entry['monitor']
        self_w, self_h = get_monitor_dimensions(mid, configured_monitors, monitor_objects)

        if entry.get('position') == 'origin':
            positions[mid] = (0, 0)
            continue

        for kw in POSITION_KEYWORDS:
            if kw not in entry:
                continue
            ref = entry[kw]
            ref_x, ref_y = positions[ref]
            ref_w, ref_h = get_monitor_dimensions(ref, configured_monitors, monitor_objects)

            if kw == 'right_of':
                positions[mid] = (ref_x + ref_w, ref_y)
            elif kw == 'left_of':
                positions[mid] = (ref_x - self_w, ref_y)
            elif kw == 'below':
                positions[mid] = (ref_x, ref_y + ref_h)
            elif kw == 'above':
                positions[mid] = (ref_x, ref_y - self_h)
            break

    return positions


def generate_config(
    workspace_config: Dict,
    monitor_objects: Dict[str, Monitor],
    configured_monitors: Dict[str, Dict],
    mirrors: Optional[Dict[str, List[Monitor]]] = None,
) -> str:
    """Generate Hyprland monitor configuration from a workspace layout.

    Produces monitor lines, $monitorN aliases, an optional disable-others
    directive, and mirror directives for duplicate physical monitors.

    If the workspace has a ``catch_all`` field (e.g. "preferred"), emits a
    catch-all rule ``monitor = ,<catch_all>,auto,1`` that enables all
    connected monitors with default settings, instead of per-monitor lines.
    """
    layout = workspace_config.get('layout', [])
    monitor_order = workspace_config.get('monitor_order', [])
    disable_others = workspace_config.get('disable_others', False)
    catch_all = workspace_config.get('catch_all')

    lines: List[str] = []

    if catch_all:
        # Catch-all mode: enable all connected monitors with auto settings
        lines.append(f"monitor = ,{catch_all},auto,1")
    else:
        positions = resolve_positions(layout, configured_monitors, monitor_objects)

        # Disable all non-configured monitors when requested
        if disable_others:
            lines.append("monitor = ,disable")

        # Emit monitor configuration lines
        for entry in layout:
            mid = entry['monitor']
            if mid not in monitor_objects:
                continue
            monitor = monitor_objects[mid]
            settings = get_monitor_settings(configured_monitors, mid)
            x, y = positions[mid]

            line = f"monitor = {monitor.name}, {settings['mode']},{x}x{y},{settings['scale']}"
            if settings['vrr']:
                line += ",vrr,1"
            lines.append(line)

        # Emit $monitorN aliases for keybindings
        for i, mid in enumerate(monitor_order):
            if mid in monitor_objects:
                lines.append(f"$monitor{i} = {monitor_objects[mid].name}")

    # Emit mirror directives for duplicate monitor entries
    if mirrors:
        for primary_name, dupes in mirrors.items():
            for dupe in dupes:
                lines.append(
                    f"monitor = {dupe.name}, preferred, auto, 1, mirror, {primary_name}"
                )

    return "\n".join(lines) + "\n"


def hyprctl_notify(message: str, color: str = "ff0000"):
    """Send a notification using hyprctl."""
    try:
        subprocess.run(
            ["hyprctl", "notify", "-1", "10000", f"rgb({color})", message],
            check=True,
            capture_output=True
        )
    except subprocess.CalledProcessError as e:
        print(f"Failed to send notification: {e}", file=sys.stderr)


def apply_monitor_config(config_content: str):
    """Apply the generated monitor configuration to Hyprland."""
    output_path = CONFIG_DIR / "monitors.conf"

    with open(output_path, 'w') as f:
        f.write(config_content)

    # Reload Hyprland config
    try:
        subprocess.run(
            ["hyprctl", "reload"],
            check=True,
            capture_output=True
        )
    except subprocess.CalledProcessError as e:
        print(f"Failed to reload Hyprland config: {e}", file=sys.stderr)


def list_workspaces(workspaces: Dict[str, Dict]) -> None:
    """Print a table of all available workspace modes."""
    print("Available monitor modes:")
    print(f"  {'Name':<30} {'Status':<10} {'Description':<45} {'Monitors'}")
    print(f"  {'-'*30} {'-'*10} {'-'*45} {'-'*30}")
    for name, config in workspaces.items():
        description = config.get('description', '')
        monitors = ', '.join(get_workspace_monitors(config)) or config.get('catch_all', '')
        status = 'enabled' if is_workspace_enabled(config) else 'disabled'
        print(f"  {name:<30} {status:<10} {description:<45} {monitors}")


def find_compatible_workspaces(
    monitor_match_map: Dict[str, List[str]],
    workspaces: Dict[str, Dict]
) -> List[Tuple[str, Dict]]:
    """
    Find all enabled workspace configurations compatible with connected monitors.
    Disabled workspaces are excluded from the toggle cycle.
    Returns a list of (workspace_name, workspace_config) sorted by monitor count descending.
    """
    all_possible_ids = set()
    for ids in monitor_match_map.values():
        all_possible_ids.update(ids)

    compatible = []
    for workspace_name, workspace_config in workspaces.items():
        if not is_workspace_enabled(workspace_config):
            continue
        required_monitors = set(get_workspace_monitors(workspace_config))
        if required_monitors.issubset(all_possible_ids):
            compatible.append((workspace_name, workspace_config))

    # Sort by monitor count descending for consistent ordering
    compatible.sort(key=lambda x: len(get_workspace_monitors(x[1])), reverse=True)
    return compatible


def get_required_monitors(workspace_config: Dict) -> set[str]:
    """Get the set of monitor config IDs required by a workspace."""
    return set(get_workspace_monitors(workspace_config))


def read_current_mode() -> Optional[str]:
    """Read the currently active monitor mode from state file."""
    try:
        return STATE_FILE.read_text().strip()
    except (FileNotFoundError, OSError):
        return None


def write_current_mode(mode_name: str) -> None:
    """Write the active monitor mode to state file."""
    try:
        STATE_FILE.parent.mkdir(parents=True, exist_ok=True)
        STATE_FILE.write_text(mode_name)
    except OSError as e:
        print(f"Warning: Could not save mode state: {e}", file=sys.stderr)


def get_next_mode(
    compatible: List[Tuple[str, Dict]],
    current_mode: Optional[str]
) -> Optional[Tuple[str, Dict]]:
    """
    Get the next mode in the cycle of compatible workspaces.
    If current mode is unknown or not in the list, returns the first compatible mode.
    """
    if not compatible:
        return None

    names = [name for name, _ in compatible]

    if current_mode in names:
        current_idx = names.index(current_mode)
        next_idx = (current_idx + 1) % len(compatible)
    else:
        next_idx = 0

    return compatible[next_idx]


def main():
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="Configure Hyprland monitor layouts based on connected displays."
    )
    parser.add_argument(
        "--mode", "-m",
        type=str,
        default=None,
        help="Explicitly select a monitor mode (workspace name) to apply"
    )
    parser.add_argument(
        "--default-mode",
        type=str,
        default=None,
        help="Default monitor mode to use instead of auto-detection (overridden by --mode). "
             "Can also be set via DEFAULT_MONITOR_MODE environment variable."
    )
    parser.add_argument(
        "--toggle", "-t",
        action="store_true",
        help="Cycle through all compatible monitor modes for the connected displays"
    )
    parser.add_argument(
        "--list-modes", "-l",
        action="store_true",
        help="List all available monitor modes and exit"
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be done without applying changes"
    )
    parser.add_argument(
        "--verbose", "-v",
        action="store_true",
        help="Show detailed output"
    )
    args = parser.parse_args()

    if args.toggle and args.mode:
        print("Error: --toggle and --mode are mutually exclusive.", file=sys.stderr)
        sys.exit(1)

    # Load configuration files
    try:
        monitors_config = load_yaml(MONITORS_YAML)
        workspaces_config = load_yaml(WORKSPACES_YAML)
    except FileNotFoundError as e:
        print(f"Error: Could not load configuration file: {e}", file=sys.stderr)
        sys.exit(1)

    configured_monitors = monitors_config.get('monitors', {})
    workspaces = workspaces_config.get('workspaces', {})

    # Validate workspace configs reference existing monitors and have valid layouts
    errors = []
    for ws_name, ws_config in workspaces.items():
        # Catch-all workspaces have no layout to validate
        if ws_config.get('catch_all'):
            continue

        layout = ws_config.get('layout', [])
        if not layout:
            errors.append(f"  Workspace '{ws_name}': missing or empty layout")
        positioned = set()
        for i, entry in enumerate(layout):
            mid = entry.get('monitor')
            if not mid:
                errors.append(f"  Workspace '{ws_name}': layout entry {i} missing 'monitor'")
                continue
            if mid not in configured_monitors:
                errors.append(f"  Workspace '{ws_name}': monitor '{mid}' not defined in monitors.yaml")
            # Validate position specification
            has_origin = entry.get('position') == 'origin'
            rel_keys = [k for k in POSITION_KEYWORDS if k in entry]
            if has_origin and rel_keys:
                errors.append(f"  Workspace '{ws_name}': monitor '{mid}' has both 'position: origin' and '{rel_keys[0]}'")
            elif not has_origin and not rel_keys:
                errors.append(f"  Workspace '{ws_name}': monitor '{mid}' has no position specified")
            elif rel_keys:
                ref = entry[rel_keys[0]]
                if ref not in positioned:
                    errors.append(f"  Workspace '{ws_name}': monitor '{mid}' references '{ref}' which is not positioned yet")
            positioned.add(mid)
        # Validate monitor_order references monitors in layout
        layout_monitors = set(get_workspace_monitors(ws_config))
        for mid in ws_config.get('monitor_order', []):
            if mid not in layout_monitors:
                errors.append(f"  Workspace '{ws_name}': monitor_order references '{mid}' not in layout")
    if errors:
        print("Configuration errors:", file=sys.stderr)
        for e in errors:
            print(e, file=sys.stderr)
        sys.exit(1)

    # Handle --list-modes
    if args.list_modes:
        list_workspaces(workspaces)
        sys.exit(0)

    # Validate --mode and --default-mode refer to known workspaces early
    if args.mode and args.mode not in workspaces:
        print(f"Error: Unknown monitor mode '{args.mode}'. Use --list-modes to see available modes.", file=sys.stderr)
        sys.exit(1)
    default_mode = args.default_mode or os.environ.get('DEFAULT_MONITOR_MODE')
    if default_mode and default_mode not in workspaces:
        print(f"Error: Unknown default monitor mode '{default_mode}'. Use --list-modes to see available modes.", file=sys.stderr)
        sys.exit(1)

    if args.verbose:
        print(f"Loaded {len(configured_monitors)} monitor configurations")
        print(f"Loaded {len(workspaces)} workspace configurations")

    # Get connected monitors and deduplicate
    try:
        raw_monitors = get_connected_monitors()
    except Exception as e:
        print(f"Error: Failed to get connected monitors: {e}", file=sys.stderr)
        sys.exit(1)

    connected, mirrors = deduplicate_monitors(raw_monitors)

    if mirrors and args.verbose:
        for primary, dupes in mirrors.items():
            dupe_names = ", ".join(d.name for d in dupes)
            print(f"  Duplicate monitors for {primary}: {dupe_names} (will mirror)")

    print(f"Connected monitors:")
    for m in connected:
        print(f"  - {m.name}: model={m.model}, serial={m.serial}")

    # Match connected monitors to configured monitors
    # A single physical display can match multiple config IDs (e.g. different
    # mode profiles), so we track all matches per display.
    monitor_match_map = {}  # Maps physical monitor name to list of config IDs
    monitor_objects = {}  # Maps config ID to Monitor object

    for monitor in connected:
        matched_ids = match_monitor(monitor, configured_monitors)
        if matched_ids:
            monitor_match_map[monitor.name] = matched_ids
            for mid in matched_ids:
                monitor_objects[mid] = monitor
            names = ", ".join(f"{mid} ({configured_monitors[mid]['name']})" for mid in matched_ids)
            print(f"  Matched: {monitor.name} -> {names}")
        else:
            print(f"  Unmatched: {monitor.name} (model={monitor.model}, serial={monitor.serial})")

    # Determine which workspace to apply
    workspace_name = None
    workspace_config = None

    if args.toggle:
        # Toggle: cycle through all compatible workspaces
        compatible = find_compatible_workspaces(monitor_match_map, workspaces)
        if not compatible:
            print("No compatible monitor modes found for connected displays.")
            if not args.dry_run:
                hyprctl_notify("No compatible modes found", color="ff0000")
            sys.exit(1)

        current_mode = read_current_mode()
        result = get_next_mode(compatible, current_mode)
        if result:
            workspace_name, workspace_config = result
            compatible_names = [n for n, _ in compatible]
            current_idx = compatible_names.index(workspace_name)
            print(f"\nToggle: cycling to mode {current_idx + 1}/{len(compatible)}")
            if args.verbose:
                print(f"  Compatible modes: {', '.join(compatible_names)}")
                print(f"  Previous mode: {current_mode or '(none)'}")

    elif args.mode:
        # Explicit mode selection
        mode = args.mode

        candidate_config = workspaces[mode]
        required = get_required_monitors(candidate_config)

        all_possible_ids = set()
        for ids in monitor_match_map.values():
            all_possible_ids.update(ids)

        if required.issubset(all_possible_ids):
            workspace_name = mode
            workspace_config = candidate_config
            print(f"\nUsing explicitly selected mode '{mode}'")
        else:
            missing = required - all_possible_ids
            print(f"Error: Mode '{mode}' requires monitors not connected: {', '.join(missing)}", file=sys.stderr)
            hyprctl_notify(f"Mode {mode} failed: missing monitors", color="ff0000")
            sys.exit(1)

    else:
        # Auto-detect: default-mode > DEFAULT_MONITOR_MODE env > best match
        if default_mode:
            candidate_config = workspaces[default_mode]
            required = get_required_monitors(candidate_config)

            all_possible_ids = set()
            for ids in monitor_match_map.values():
                all_possible_ids.update(ids)

            if required.issubset(all_possible_ids):
                workspace_name = default_mode
                workspace_config = candidate_config
                source = "--default-mode" if args.default_mode else "DEFAULT_MONITOR_MODE env"
                print(f"\nUsing default mode '{default_mode}' (via {source})")
            else:
                missing = required - all_possible_ids
                print(f"Warning: Default mode '{default_mode}' requires monitors not connected: {', '.join(missing)}")
                print("Falling back to auto-detection...")

        if workspace_config is None:
            # Auto-detect best workspace
            result = find_matching_workspace(monitor_match_map, workspaces)
            if result:
                workspace_name, workspace_config = result

    # Apply the selected workspace
    if workspace_config:
        description = workspace_config.get('description', workspace_name)

        print(f"\nSelected workspace: {workspace_name} ({description})")

        config_content = generate_config(
            workspace_config, monitor_objects, configured_monitors, mirrors
        )

        if args.dry_run:
            print("\n--- Dry run mode - would apply the following configuration: ---")
            print(config_content)
            print("--- End of configuration ---")
        else:
            apply_monitor_config(config_content)
            write_current_mode(workspace_name)
            hyprctl_notify(f"{description} enabled")
            print(f"Configuration applied successfully.")
    else:
        # Default to laptop mode
        default_workspace = workspaces.get('default_laptop')
        if default_workspace:
            config_content = generate_config(
                default_workspace, monitor_objects, configured_monitors, mirrors
            )

            if args.dry_run:
                print("\n--- Dry run mode - would apply default laptop configuration: ---")
                print(config_content)
                print("--- End of configuration ---")
            else:
                apply_monitor_config(config_content)
                write_current_mode('default_laptop')

        if not args.dry_run:
            hyprctl_notify("Default laptop mode enabled")
        print("No matching workspace found. Applied default laptop mode.")


if __name__ == "__main__":
    main()
